# Stripe Configuration
# Get your publishable key from: https://dashboard.stripe.com/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Backend API Configuration
# Update this to your backend URL in production
VITE_BACKEND_API=http://localhost:3000
VITE_API_TIMEOUT=30000

# App Configuration
VITE_APP_ENV=development
VITE_LOG_LEVEL=debug

# Feature Flags
VITE_ENABLE_ADMIN_CONTROLS=false
VITE_ENABLE_LIVE_STREAMING=false
VITE_ENABLE_PAYMENTS=false

# Note: NEVER commit actual keys to this file.
# Use Vercel Environment Variables or GitHub Secrets for sensitive data.
# See SECURITY.md for detailed instructions.
