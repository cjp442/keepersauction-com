# ============================================================
# VITE_ prefixed vars are bundled into the client (public)
# All others are server-only (Vercel Functions / CI only)
# ============================================================

# --- Supabase (client-safe) ---
VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# --- Stripe (client-safe — public key only) ---
VITE_STRIPE_PUBLIC_KEY=pk_live_<your-publishable-key>

# --- Site config (client-safe) ---
VITE_SITE_NAME=KeepersAuction
VITE_DOMAIN=https://keepersauction.com
VITE_HOST_PHONE=606-412-3121

# --- Feature flags (client-safe) ---
VITE_ENABLE_DONATIONS=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_3D_ROOMS=true
VITE_ENABLE_GAMES=true

# ============================================================
# SERVER-ONLY secrets — set these in Vercel dashboard or
# GitHub Actions secrets. NEVER prefix with VITE_.
# ============================================================

# --- Stripe server secrets ---
STRIPE_SECRET_KEY=sk_live_<your-secret-key>
STRIPE_WEBHOOK_SECRET=whsec_<your-webhook-signing-secret>

# Optional: default Stripe Price ID for token purchases
# STRIPE_TOKEN_PRICE_ID=price_<your-price-id>

# --- Supabase service role (server-only) ---
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ============================================================
# Vercel deployment (GitHub Actions secrets — do NOT put real values here)
# ============================================================
# VERCEL_TOKEN: API token from https://vercel.com/account/tokens
# VERCEL_ORG_ID: Found in Vercel project settings or via `vercel whoami`
# VERCEL_PROJECT_ID: Found in Vercel project settings
