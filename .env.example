# Environment Variables Example

# Supabase
SUPABASE_URL=https://<your-supabase-url>
SUPABASE_ANON_KEY=<your-anon-key>

# Stripe
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_PUBLIC_KEY=<your-stripe-public-key>

# Payment Processing
STRIPE_SECRET_KEY=••••••••••••••••
STRIPE_WEBHOOK_SECRET=••••••••••••••••
VITE_STRIPE_KEY=your_stripe_publishable_key

# Site Configuration
VITE_SITE_NAME=CoinKeepersAuction
VITE_DOMAIN=coinkeepersauction.com
VITE_HOST_PHONE=606-412-3121

# Feature Flags
VITE_ENABLE_DONATIONS=true
VITE_ENABLE_AUCTIONS=true
VITE_ENABLE_3D_ROOMS=true
VITE_ENABLE_GAMES=true

# Game Debug
VITE_GAME_DEBUG=false
